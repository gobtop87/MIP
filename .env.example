# Optional: sign up for a free key at https://newsapi.org/register
# Without this, the pipeline still runs using SEC EDGAR + RSS feeds.
NEWSAPI_KEY=

# Optional: used by news_watch/backfill_summaries.py to write real 4-5
# sentence source summaries (via Claude fetching the article at each item's
# URL) instead of whatever short description the feed provided.
ANTHROPIC_API_KEY=

# Optional: enables POST /api/refresh-news (pulls fresh news + backfills
# summaries), used by .github/workflows/refresh-news.yml to keep the
# deployed site's news updated on a schedule. Pick any random string and set
# the same value here, in Render's environment settings, and as the
# REFRESH_SECRET GitHub Actions secret.
REFRESH_SECRET=
